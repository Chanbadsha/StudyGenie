# ─── Application ──────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=StudyGenie
# Must match the deployed frontend URL in production (e.g. https://studygenie.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Must match the deployed backend URL in production (e.g. https://studygenie-api.onrender.com/api/v1)
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# ─── Google OAuth (optional) ─────────────────────────────
# Must match the Google Cloud Console authorized JavaScript origins
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
