# ─── Application ──────────────────────────────────────────
# NODE_ENV=development | production
NODE_ENV=development
PORT=5000
# Comma-separated for multiple origins (e.g. http://localhost:3000,https://studygenie.vercel.app)
CLIENT_URL=http://localhost:3000

# ─── MongoDB ──────────────────────────────────────────────
# Use MongoDB Atlas SRV string for production
MONGODB_URI=mongodb://localhost:27017/studygenie
DATABASE_NAME=studygenie

# ─── Better Auth ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_with_secure_random_secret
# Must match the deployed backend URL in production (e.g. https://studygenie-api.onrender.com)
BETTER_AUTH_URL=http://localhost:5000

# ─── Google OAuth (optional — omit to disable) ────────────
# Use production Google Cloud Console credentials for deployed environment
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Gemini AI ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
